# ─── GitHub ───
# Bot PAT or App token with repo write access on the repos HealX should repair.
GITHUB_TOKEN=ghp_your_token_here
# HMAC-SHA256 secret shared with the GitHub webhook config.
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ─── LLM ───
# Anthropic API key (Claude Opus 4.7).
API_KEY=sk-ant-your_key_here

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://healx:healx@localhost:5432/healx

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── Observability ───
# Leave blank to disable Langfuse tracing cleanly.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── App ───
APP_ENV=development
LOG_LEVEL=INFO
